TORBOXARR_TORBOX_API_TOKEN=
TORBOXARR_QBIT_PASSWORD=
TORBOXARR_SAB_API_KEY=

# Optional overrides
# TORBOXARR_SERVER_BASE_URL=http://localhost:8085
# File storage root for staging, completed files, and payloads.
# TORBOXARR_DATA_ROOT=/data
# Optional database path override. The bundled compose file sets this to /config/torboxarr.db.
# Direct binary runs still default to /var/lib/torboxarr/torboxarr.db unless you override it.
# TORBOXARR_DATABASE_PATH=/config/torboxarr.db
# TORBOXARR_LOG_LEVEL=INFO
